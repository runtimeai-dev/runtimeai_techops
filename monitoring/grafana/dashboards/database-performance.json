{
  "dashboard": {
    "title": "Database Performance",
    "tags": ["database", "postgresql", "performance"],
    "panels": [
      {
        "title": "Connection Pool Status",
        "targets": [
          {
            "expr": "pg_stat_activity_count{datname=\"rt19\"}",
            "legendFormat": "Active Connections"
          }
        ],
        "type": "stat"
      },
      {
        "title": "Query Latency (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, pg_slow_queries_duration_seconds_bucket)",
            "legendFormat": "Slow Query p95"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Cache Hit Ratio",
        "targets": [
          {
            "expr": "100 * sum(pg_stat_user_tables_idx_blks_hit) / (sum(pg_stat_user_tables_idx_blks_hit) + sum(pg_stat_user_tables_idx_blks_read))",
            "legendFormat": "Hit Ratio %"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Table Size Growth",
        "targets": [
          {
            "expr": "pg_table_size_bytes / 1024^3",
            "legendFormat": "{{ tablename }} (GB)"
          }
        ],
        "type": "graph"
      }
    ]
  }
}
