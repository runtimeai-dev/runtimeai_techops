# Customer Environment Variables Template
# Copy to .env and fill in values provided by RuntimeAI

# ── Control Plane Connection (provided by RuntimeAI) ──
CONTROL_PLANE_URL=https://cp.runtimeai.example.com
DATABASE_URL=postgresql://runtimeai:CHANGE_ME@cp-db.runtimeai.example.com:5432/authzion?sslmode=require
REDIS_URL=redis://:CHANGE_ME@cp-redis.runtimeai.example.com:6379/0
API_KEY_SECRET=CHANGE_ME_PROVIDED_BY_RUNTIMEAI
OPA_URL=http://cp.runtimeai.example.com:8181/v1/data/authzion/allow
# CP_HOST = Control Plane IP address (for internal-api hostname resolution)
CP_HOST=CHANGE_ME_TO_CP_IP

# ── Image Version ──
VERSION=latest

# ── Tenant Configuration ──
TENANT_ID=your-tenant-id

# ── Optional: Custom Ports ──
# Uncomment to override default ports
# ENFORCER_PORT=8092
# WAF_PORT=8101
# DISCOVERY_PORT=8090
