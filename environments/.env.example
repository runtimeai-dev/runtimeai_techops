# Schwab API Credentials
# Get these from https://developer.schwab.com after creating an app

# Your App Key (Client ID)
SCHWAB_CLIENT_ID=your_app_key_here

# Your App Secret (Client Secret)
SCHWAB_CLIENT_SECRET=your_app_secret_here

# Callback URL (must match what you configured in Schwab Developer Portal)
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Account Identification
# Run 'python3 schwab_trade_analyzer.py --accounts' to see your account numbers
# Enter the last 4 digits or full account number to identify each account
SCHWAB_IRA_ACCOUNT=1234
SCHWAB_IND_ACCOUNT=5678

# OAuth Tokens (automatically populated after running --auth)
# Do not edit these manually
# SCHWAB_ACCESS_TOKEN=
# SCHWAB_REFRESH_TOKEN=
# SCHWAB_TOKEN_EXPIRES=
