apiVersion: v1
kind: Secret
metadata:
  name: arh-secrets
  namespace: runtimecrm
type: Opaque
stringData:
  DATABASE_URL: "REPLACE_ME"
  # CRITICAL: AUTH_JWT_ISSUER must be exactly "auth.runtimeai.com" — no scheme, no host prefix.
  # Any URL-form value causes every JWT verification to fail with 401.
  AUTH_JWT_ISSUER: "auth.runtimeai.com"
  # auth-svc hostname in rt19 namespace — note "auth-svc" not "auth-service"
  AUTH_JWKS_URL: "http://auth-svc.rt19.svc.cluster.local:8097/.well-known/jwks.json"
  AUTH_SERVICE_URL: "http://auth-svc.rt19.svc.cluster.local:8097"
  AUTH_ADMIN_SECRET: "REPLACE_ME"
  BILLING_API_KEY: "REPLACE_ME"
  BILLING_WEBHOOK_SECRET: "REPLACE_ME"
  LLM_BROKER_PROXY_KEY: "REPLACE_ME"
  SMTP_USER: "REPLACE_ME"
  SMTP_PASSWORD: "REPLACE_ME"
  SMTP_FROM: "noreply@runtimecrm.com"
  SENDGRID_API_KEY: "REPLACE_ME"
  SENDGRID_FROM_EMAIL: "noreply@runtimecrm.com"
  CALENDLY_WEBHOOK_SECRET: "REPLACE_ME"
  INBOUND_EMAIL_SECRET: "REPLACE_ME"
  BOUNCE_WEBHOOK_SECRET: "REPLACE_ME"
  GMAIL_OAUTH_CLIENT_ID: ""
  GMAIL_OAUTH_CLIENT_SECRET: ""
  GMAIL_OAUTH_REDIRECT_URI: "https://api.runtimecrm.io/api/v1/email-accounts/gmail/callback"
  OUTLOOK_OAUTH_CLIENT_ID: ""
  OUTLOOK_OAUTH_CLIENT_SECRET: ""
  OUTLOOK_OAUTH_REDIRECT_URI: "https://api.runtimecrm.io/api/v1/email-accounts/outlook/callback"
  SLACK_WEBHOOK_URL: ""
  ADMIN_API_SECRET: "REPLACE_ME"
